# ═════════════════════════════════════════════════════════════════════════════
# TRUGYDEX EMAIL CAMPAIGN PLATFORM - ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# IMPORTANT: NEVER commit .env file to GitHub (add to .gitignore)

# ─── MongoDB Database Configuration ─────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/trugydex

# ─── Gmail Configuration ────────────────────────────────────────────────────
# 1. Enable 2-Step Verification in your Google Account
# 2. Generate an App Password at: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character password below
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_SENDER_NAME=Trugydex

# ─── JWT Authentication Secret ──────────────────────────────────────────────
# Generate a strong random string (minimum 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long

# ─── Initial Admin Account Setup ────────────────────────────────────────────
# These are used only once to seed the admin user via GET /api/auth/seed
ADMIN_NAME=Trugydex Admin
ADMIN_EMAIL=admin@trugydex.in
ADMIN_PASSWORD=AdminPassword123

# ─── Server Configuration ───────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Email Sending Configuration ────────────────────────────────────────────
# Batch size for sending emails (default: 10)
EMAIL_BATCH_SIZE=10

# Delay between batches in milliseconds (default: 2000)
EMAIL_BATCH_DELAY=2000

# Maximum retries for failed emails (default: 3)
EMAIL_MAX_RETRIES=3

# ─── Frontend Configuration ─────────────────────────────────────────────────
# API Base URL should point to your backend
API_BASE=https://mail.trugydex.in/api

# ─── Optional: SendGrid Alternative (if using SendGrid instead of Gmail) ─────
# SENDGRID_API_KEY=SG.xxx...
